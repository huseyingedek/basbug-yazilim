<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS + httpPlatformHandler.
  Sunucudaki gerçek yollara göre ayarlandı:
    Site      : C:\inetpub\wwwroot\MUTABAKAT
    Sanal ortam: ...\venv\Scripts\python.exe

  DİKKAT: handler'da path="*" verb="*" OLMALI. Boş ("") olursa IIS istekleri
  Python'a hiç yönlendirmez (502 / "python'a erişemiyor" sebebi budur).
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="PythonHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified" />
    </handlers>

    <httpPlatform processPath="C:\inetpub\wwwroot\MUTABAKAT\venv\Scripts\python.exe"
                  arguments="serve.py"
                  workingDirectory="C:\inetpub\wwwroot\MUTABAKAT"
                  stdoutLogEnabled="true"
                  stdoutLogFile="C:\inetpub\wwwroot\MUTABAKAT\logs\stdout.log"
                  startupTimeLimit="60"
                  startupRetryCount="3"
                  requestTimeout="00:04:00">
      <environmentVariables>
        <environmentVariable name="PYTHONUNBUFFERED" value="1" />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>
