<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS + httpPlatformHandler (SUNUCUDA ÇALIŞAN, DOĞRULANMIŞ CONFIG).

  ÖNEMLİ / DERS: Bu config'i SADE tut. Eski httpPlatformHandler sürümleri
  fazladan öznitelikleri (workingDirectory, environmentVariables,
  startupRetryCount, requestTimeout) sindiremeyip süreci başlatamaz ve
  "HTTP 502.3 - 0x8007000d" verir (stdout.log bile oluşmaz).
  Bu yüzden:
    - 'arguments' içinde serve.py'nin TAM yolunu ver (workingDirectory'ye güvenme).
    - Aşağıdaki minimum öznitelik setinin dışına çıkma.

  Sunucuya özel yollar:
    Site       : C:\inetpub\wwwroot\MUTABAKAT
    Sanal ortam: ...\venv\Scripts\python.exe
  Not: handler'da path="*" verb="*" OLMALI (boş olursa istekler Python'a gitmez).
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="PythonHandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" />
    </handlers>
    <httpPlatform processPath="C:\inetpub\wwwroot\MUTABAKAT\venv\Scripts\python.exe"
                  arguments="C:\inetpub\wwwroot\MUTABAKAT\serve.py"
                  stdoutLogEnabled="true"
                  stdoutLogFile="C:\inetpub\wwwroot\MUTABAKAT\logs\stdout.log"
                  startupTimeLimit="120">
    </httpPlatform>
  </system.webServer>
</configuration>
