# === Django (temel) ===
SECRET_KEY=degistir-bu-anahtari-uretimde
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# === Mutabakat veri kaynağı ===
# mock -> yerel örnek veri (geliştirme / tasarım)
# erp  -> İbrahim'in gerçek servisi
MUTABAKAT_DATA_SOURCE=mock

# Servisin adresi (veriyi buradan çekeceğiz / kararı buraya ileteceğiz).
# erp'ye geçince doldurulur.
SERVIS_URL=

# === Üretim (DEBUG=False iken devreye girer) ===
# HTTPS'e zorla (ters vekil arkasında SECURE_PROXY_SSL_HEADER ile birlikte çalışır)
# SECURE_SSL_REDIRECT=True
# CSRF için güvenilir kaynak(lar), virgülle ayrılmış tam adres:
# CSRF_TRUSTED_ORIGINS=https://mutabik.basbug.com.tr

# Not: Bu proje bir FRONTEND / görüntü katmanıdır ve VERİTABANI KULLANMAZ.
# Veriyi servisten çeker, kararı servise geri yollar. Ayrı bir veritabanı
# ya da auth token gerekmez. (Servis kimlik doğrulama isterse ileride buraya
# SERVIS_TOKEN eklenir.)
